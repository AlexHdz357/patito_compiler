WHITESPACE = _{ " " | "\t" | "\n" }

/////////////////////
// TOKENS
/////////////////////

id = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }

cte_ent = @{ ASCII_DIGIT+ }

cte_flot = @{
    ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+
}

TIPO = {
    "entero"
    | "flotante"
}

/////////////////////
// PALABRAS RESERVADAS
/////////////////////

programa = { "programa" }
vars = { "vars" }
inicio = { "inicio" }
fin = { "fin" }

si = { "si" }
sino = { "sino" }

mientras = { "mientras" }
haz = { "haz" }

escribe = { "escribe" }

regresa = { "return" }

/////////////////////
// PROGRAMA
/////////////////////

program = {
    SOI
    ~ programa
    ~ id
    ~ ";"
    ~ vars_block
    ~ funcs
    ~ inicio
    ~ cuerpo
    ~ fin
    ~ EOI
}

/////////////////////
// VARIABLES
/////////////////////

vars_block = {
    (vars ~ ":" ~ lista_vars)?
}

lista_vars = {
    (id ~ ":" ~ TIPO ~ ";")*
}

/////////////////////
// FUNCIONES
/////////////////////

funcs = {
    (func)*
}

parametros = {
    (id ~ ":" ~ TIPO ~ ("," ~ id ~ ":" ~ TIPO)*)?
}

argumentos = {
    (expresion ~ ("," ~ expresion)*)?
}

func = {
    TIPO
    ~ id
    ~ "("
    ~ parametros
    ~ ")"
    ~ "{"
    ~ cuerpo
    ~ "}"
}

llamada = {
    id
    ~ "("
    ~ argumentos
    ~ ")"
    ~ ";"
}


/////////////////////
// CUERPO
/////////////////////

cuerpo = {
    (estatuto)*
}

estatuto = {
      asigna
    | condicion
    | ciclo
    | imprime
    | llamada
    | retorno
}

/////////////////////
// ESTATUTOS
/////////////////////

asigna = {
    id ~ "=" ~ expresion ~ ";"
}

imprime = {
    escribe ~ "(" ~ expresion ~ ")" ~ ";"
}

retorno = {
    regresa ~ expresion ~ ";"
}

condicion = {
    si
    ~ "("
    ~ expresion
    ~ ")"
    ~ "{"
    ~ cuerpo
    ~ "}"
    ~ (sino ~ "{" ~ cuerpo ~ "}")?
}

ciclo = {
    mientras
    ~ "("
    ~ expresion
    ~ ")"
    ~ haz
    ~ "{"
    ~ cuerpo
    ~ "}"
}


/////////////////////
// EXPRESIONES
/////////////////////

expresion = {
    exp
    ~ (op_rel ~ exp)?
}

op_rel = {
      ">="
    | "<="
    | "=="
    | "!="
    | ">"
    | "<"
}

op_suma = {
      "+"
    | "-"
}

op_mult = {
      "*"
    | "/"
}

exp = {
    termino
    ~ (op_suma ~ termino)*
}

termino = {
    factor
    ~ (op_mult ~ factor)*
}

factor = {
      "(" ~ expresion ~ ")"
    | id
    | cte
}

cte = {
    cte_flot
    | cte_ent
}